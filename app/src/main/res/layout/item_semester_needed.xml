<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    android:backgroundTint="?attr/colorSurfaceVariant">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvSemLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Semester 5"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/tvNeededVal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="needs 9.50"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginEnd="8dp" />

            <!-- Status chip -->
            <TextView
                android:id="@+id/tvStatusChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="achievable"
                android:textSize="11sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:background="@drawable/bg_chip_green"
                android:textColor="@color/chip_green_text" />

        </LinearLayout>

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progressSem"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:max="100"
            android:progress="50"
            android:progressDrawable="@drawable/progress_bar_rounded" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>